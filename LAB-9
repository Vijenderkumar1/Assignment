#perform the k-mean on the given dataset?
import pandas as pd
import numpy as np
from sklearn.cluster import KMeans
from sklearn.preprocessing import StandardScaler

def run_kmeans(X, k=3):
    X = X.fillna(X.mean(numeric_only=True))

    scaler = StandardScaler()
    X_scaled = scaler.fit_transform(X)

    kmeans = KMeans(n_clusters=k, random_state=42)
    labels = kmeans.fit_predict(X_scaled)

    return labels


# DIABETES
df = pd.read_csv("diabetes.csv")
X1 = df.drop(columns=["Outcome"])
labels1 = run_kmeans(X1, k=3)


# SOCIAL ADS
df = pd.read_csv("Social_Network_Ads.csv")
df = df.drop(columns=["User ID"])
df["Gender"] = df["Gender"].map({"Male": 0, "Female": 1})

X2 = df[["Age", "EstimatedSalary", "Gender"]]
labels2 = run_kmeans(X2, k=3)


# TITANIC
df = pd.read_csv("titanic.csv")
df["Sex"] = df["Sex"].map({"male": 0, "female": 1})
df = df[["Pclass", "Sex", "Age", "Fare"]]

X3 = df
labels3 = run_kmeans(X3, k=3)


print("Diabetes Clusters:\n", labels1)
print("\nSocial Ads Clusters:\n", labels2)
print("\nTitanic Clusters:\n", labels3)
