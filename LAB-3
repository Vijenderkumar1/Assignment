#1) WAP impliment to linear regression model program on given data set also find the accuracy f1 and plot the ROC curve
import pandas as pd
import numpy as np

from sklearn.linear_model import LinearRegression
from sklearn.model_selection import train_test_split
from sklearn.metrics import r2_score

# Load dataset
df = pd.read_csv("daily-minimum-temperatures-in-me.csv")

# Data preprocessing
df["Date"] = pd.to_datetime(df["Date"], errors="coerce")
df["Daily minimum temperatures"] = pd.to_numeric(
    df["Daily minimum temperatures"], errors="coerce"
)

df = df.dropna()

# Feature engineering
df["day_index"] = (df["Date"] - df["Date"].min()).dt.days

# Define X and y
X = df[["day_index"]]
y = df["Daily minimum temperatures"]

# Train-test split
X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.3, random_state=42
)

# Model training
model1 = LinearRegression()
model1.fit(X_train, y_train)

# Prediction
y_pred1 = model1.predict(X_test)

# R2 Score (split)
r2_split = r2_score(y_test, y_pred1)
print(f"R2 Score (Train-Test split): {r2_split}")

# Full dataset model
model2 = LinearRegression()
model2.fit(X, y)

y_pred2 = model2.predict(X)

r2_full = r2_score(y, y_pred2)
print(f"R2 Score (Full Data): {r2_full}")
#2) WAP to implement the multiple linear regression programm and find out the accuracy f1 and ROC curve. Also compare the performance of linear regression model and multiple linear regression model.
import pandas as pd
import numpy as np

from sklearn.linear_model import LinearRegression
from sklearn.model_selection import train_test_split
from sklearn.metrics import r2_score

# Load dataset
df = pd.read_csv("daily-minimum-temperature-in-me-copy.csv")

# Clean column names
df.columns = df.columns.str.strip()

# Drop unwanted columns
df = df.drop(columns=["Unnamed: 2", "Unnamed: 3"], errors="ignore")

# Data preprocessing
df["Date"] = pd.to_datetime(df["Date"], errors="coerce")

df["Daily minimum temperatures"] = pd.to_numeric(
    df["Daily minimum temperatures"], errors="coerce"
)

df["Humidity"] = pd.to_numeric(df["Humidity"], errors="coerce")

df = df.dropna()

# Feature engineering
df["day_index"] = (df["Date"] - df["Date"].min()).dt.days

# Define X and y
X = df[["day_index", "Humidity"]]
y = df["Daily minimum temperatures"]

# Train-test split
X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.3, random_state=42
)

# Model training
model1 = LinearRegression()
model1.fit(X_train, y_train)

# Prediction
y_pred1 = model1.predict(X_test)

# R2 Score (split)
r2_split = r2_score(y_test, y_pred1)
print("R2 Score (Train-Test split):", r2_split)

# Full dataset model
model2 = LinearRegression()
model2.fit(X, y)

y_pred2 = model2.predict(X)

r2_full = r2_score(y, y_pred2)
print("R2 Score (Full Data):", r2_full)
